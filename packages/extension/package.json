{
  "name": "@melledijkstra/extension",
  "version": "1.0.1",
  "description": "Reusable browser extension code",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.33",
    "@types/webextension-polyfill": "^0.12.3",
    "webextension-polyfill": "^0.12.0"
  },
  "dependencies": {
    "@melledijkstra/config": "workspace:*",
    "@melledijkstra/toolbox": "workspace:*",
    "@melledijkstra/storage": "workspace:*",
    "@melledijkstra/auth": "workspace:*"
  }
}